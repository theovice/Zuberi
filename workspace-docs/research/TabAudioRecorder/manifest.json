{
  "manifest_version": 3,
  "name": "Tab Audio Recorder & Transcriber",
  "description": "Record tab audio and transcribe via Whisper on CEG.",
  "version": "1.1",
  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "http://100.100.101.1:8200/*",
    "http://100.100.101.1:3003/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
